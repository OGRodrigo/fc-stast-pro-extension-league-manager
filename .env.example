# ── BACKEND CONFIGURATION ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── DATABASE ──────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas recommended for production)
# Get from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?appName=Cluster0

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# Generate secure JWT secret: `openssl rand -hex 64`
JWT_SECRET=your-256-bit-hex-secret-here
JWT_EXPIRES_IN=7d

# ── FRONTEND URLS ─────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated)
# Development: http://localhost:5173
# Production: https://your-vercel-domain.com
CLIENT_URL=http://localhost:5173

# Frontend URL for redirects (password reset links, etc)
# Development: http://localhost:5173
# Production: https://your-vercel-domain.com
FRONTEND_URL=http://localhost:5173

# ── AI & OCR ──────────────────────────────────────────────────────────────────
# Azure Computer Vision (OCR)
# Get from: https://portal.azure.com
AZURE_VISION_ENDPOINT=https://your-region.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-azure-vision-key
AZURE_VISION_API_VERSION=2023-10-01

# OpenAI API (for structured extraction — optional)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Confidence thresholds for AI validation (0-1)
AI_SCORE_CONFIDENCE_MIN=0.85
AI_STATS_CONFIDENCE_MIN=0.70
AI_IMPORT_MAX_IMAGES=10

# ── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
# Gmail App Password recommended (not your main password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=FC Stats Pro <your-email@gmail.com>
