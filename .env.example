# ────────────────────────────────────────────────────────────────────────────
# FC Stats Pro League Manager — Variables de entorno (.env)
# ────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena con tus valores

# ─── SERVIDOR ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── BASE DE DATOS ──────────────────────────────────────────────────────────
# MongoDB Local
# MONGO_URI=mongodb://localhost:27017/fc_stats_pro

# MongoDB Atlas (nube - recomendado)
MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/fc_stats_pro?appName=Cluster0

# ─── AUTENTICACIÓN ──────────────────────────────────────────────────────────
# JWT Secret — IMPORTANTE: usar mínimo 32 caracteres aleatorios seguros
# Generar con: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-min-32-chars

# Expiración del token
JWT_EXPIRES_IN=7d

# ─── CORS (URLs permitidas) ─────────────────────────────────────────────────
# Separar múltiples URLs con comas
CLIENT_URL=http://localhost:5173

# Para producción:
# CLIENT_URL=https://app.ejemplo.com,https://www.app.ejemplo.com

# ─── AI / OCR (Azure Computer Vision) ────────────────────────────────────────
# Crear en: https://portal.azure.com → Computer Vision → Create

AZURE_VISION_ENDPOINT=https://tu-region.cognitiveservices.azure.com/
AZURE_VISION_KEY=tu_azure_vision_key_aqui
AZURE_VISION_API_VERSION=2023-10-01

# ─── IA (OpenAI — OPCIONAL) ─────────────────────────────────────────────────
# Crear en: https://platform.openai.com/api-keys
# Si NO se define, el sistema usa solo Azure OCR + heurísticas

OPENAI_API_KEY=sk-proj-tu_openai_key_aqui
OPENAI_MODEL=gpt-4o-mini

# ─── CONFIANZA EN IA (umbrales 0-1) ──────────────────────────────────────────
# Mínimo para mostrar como válido
AI_SCORE_CONFIDENCE_MIN=0.85

# Mínimo para incluir en estadísticas
AI_STATS_CONFIDENCE_MIN=0.70

# Máximo de imágenes por importación
AI_IMPORT_MAX_IMAGES=10

# ─── EMAIL (SMTP) ────────────────────────────────────────────────────────────
# Gmail: https://myaccount.google.com/apppasswords
# Obtiene una contraseña de 16 caracteres específica para esta app

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Dirección de remitente
SMTP_FROM=FC Stats Pro <your_email@gmail.com>

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
# Ventana en milisegundos
RATE_LIMIT_WINDOW_MS=900000

# Máximo de requests por ventana
RATE_LIMIT_MAX_REQUESTS=100

# ─── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Valores: debug, info, warn, error

# ─── DEBUGGING ───────────────────────────────────────────────────────────────
DEBUG=false
# Habilitar logs detallados: DEBUG=true

# ────────────────────────────────────────────────────────────────────────────
# NOTAS:
# • No commits .env a Git (está en .gitignore)
# • JWT_SECRET debe ser único y seguro en producción
# • MONGO_URI no debe contener caracteres especiales sin encoding
# • Si usas Windows, asegúrate de que .env está en UTF-8
# ────────────────────────────────────────────────────────────────────────────