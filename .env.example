PORT=3000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/fc_stats_pro_league_manager

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

# ── AI / OCR ─────────────────────────────────────────────
# Azure Computer Vision (OCR principal)
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_VISION_KEY=your_azure_vision_key_here
AZURE_VISION_API_VERSION=2023-10-01

# OpenAI (validación y extracción estructurada — opcional)
# Si no se define, el pipeline usa solo heurísticas + Azure OCR
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Umbrales de confianza (0-1)
AI_SCORE_CONFIDENCE_MIN=0.85
AI_STATS_CONFIDENCE_MIN=0.70
AI_IMPORT_MAX_IMAGES=10